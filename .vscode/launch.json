{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    // k8shell-db-postgresql-dev
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Go provisioner",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "cmd/provisioner/main.go", // Path to your Go file or main package
            "env": {
                "SECRET_FILES": "/opt/shared/provisioner/secrets",
                "WORKSPACE_REGISTRY": "fitcr.ksi.in.fit.cvut.cz",
                "WORKSPACE_STORAGE_CLASS": "zfs-csi-k8shell-test",
                "HELM_DEBUG": "true",
                "HELM_DEBUG_MANIFEST": "true",
            },
            "cwd": "${workspaceFolder}",
            "args": [
                "--logtext",
                "--config",
                "config/config.yaml"
            ],
            "showLog": true
            //"stopOnEntry": true
        }
    ]
}