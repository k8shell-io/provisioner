    "version": "0.2.0",
    "configurations": [
        {
            "name": "Go provisioner",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "main.go",
            "env": {
                "SECRET_FILES": "/opt/shared/provisioner/secrets",
                "WORKSPACE_REGISTRY": "registry.k8shell.io",
                "WORKSPACE_STORAGE_CLASS": "zfs-csi-k8shell-test",
                // "TARGET_NAMESPACE": "workspaces-test", // k8shell-workspace
                "TARGET_NAMESPACE": "workspaces-staging",
                "IDENTITY_SERVICE_URL": "http://identity.k8shell-test:9090",
                //"IDENTITY_SERVICE_URL": "http://10.42.3.57:9090",
                "TOKEN_PROVISIONER": "3osh3FlS4sSqbxh3DIuG9lcQAV39evpZDbvQuhLAKHo5GuzYzm25lA7rnieSCEc9",
                "HELM_DEBUG": "true",
                "HELM_DEBUG_MANIFEST": "true",
            },
            "cwd": "${workspaceFolder}",
            "args": [
                "--logtext",
                "--config",
                "config/config.yaml"
            ],
            "showLog": true,
            //"stopOnEntry": true
        }
    ]
}